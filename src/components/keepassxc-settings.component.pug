h3([textContent]='translate.trans("settings.title")')
.mb-3([textContent]='translate.trans("settings.sub_title")')

.row
    .col-md-12
        .form-line
            .header
                .title
                    i.fas.fa-fw.fa-power-off.mr-2
                    span([textContent]='translate.trans("settings.enabled")')
            toggle([(ngModel)]='settings.enabled')

        .form-line
            .header
                .title
                    i.fas.fa-fw.fa-link.mr-2
                    span([textContent]='translate.trans("settings.entry_url")')
            input.form-control([(ngModel)]='settings.entryUrl', type='text')
            small.text-muted([textContent]='translate.trans("settings.entry_url_hint")')

        .form-line
            .header
                .title
                    i.fas.fa-fw.fa-terminal.mr-2
                    span([textContent]='translate.trans("settings.cli_path")')
            input.form-control([(ngModel)]='settings.cliPath', type='text', [placeholder]='detectedCliPath')
            small.text-muted([textContent]='translate.trans("settings.cli_path_hint")')

        .form-line
            .header
                .title
                    i.fas.fa-fw.fa-lock-open.mr-2
                    span([textContent]='translate.trans("settings.wait_for_unlock")')
            toggle([(ngModel)]='settings.waitForUnlock')
            small.text-muted([textContent]='translate.trans("settings.wait_for_unlock_hint")')

        .form-line
            .header
                .title
                    i.fas.fa-fw.fa-clock.mr-2
                    span([textContent]='translate.trans("settings.remember_minutes")')
            select.form-control([(ngModel)]='settings.rememberMinutes')
                option(*ngFor='let item of rememberOptions', [ngValue]='item.value') {{ transOption(item) }}

        .form-line
            .header
                .title
                    i.fas.fa-fw.fa-random.mr-2
                    span([textContent]='translate.trans("settings.fallback")')
            select.form-control([(ngModel)]='settings.fallback')
                option(*ngFor='let item of fallbackOptions', [ngValue]='item.value') {{ transOption(item) }}

        .form-line
            .header
                .title
                    i.fas.fa-fw.fa-file.mr-2
                    span([textContent]='translate.trans("settings.association_file")')
            input.form-control([(ngModel)]='settings.associationFile', type='text', [placeholder]='defaultAssociationHint()')
            small.text-muted([textContent]='translate.trans("settings.association_file_hint")')

        .form-line.association-status
            .header
                .title
                    i.fas.fa-fw.fa-plug.mr-2
                    span([textContent]='translate.trans("settings.association_status")')
            span.status-badge([class.status-ok]='associationStatus === "ok"', [class.status-fail]='associationStatus === "fail"') {{ associationStatusLabel() }}

        .form-line.actions
            button.btn.btn-primary.mr-2(type='button', (click)='saveSettings()', [disabled]='saving')
                i.fas.fa-save.mr-1
                span([textContent]='translate.trans("settings.save")')
            button.btn.btn-secondary.mr-2(type='button', (click)='testFetch()', [disabled]='testing')
                i.fas.fa-vial.mr-1
                span([textContent]='translate.trans("settings.test_fetch")')
            button.btn.btn-outline-secondary(type='button', (click)='clearCachedPassphrase()')
                i.fas.fa-eraser.mr-1
                span([textContent]='translate.trans("settings.clear_cache")')
