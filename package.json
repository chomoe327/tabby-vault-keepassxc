{
  "name": "tabby-vault-keepassxc",
  "version": "0.1.0",
  "description": "Automatically unlock Tabby Vault using KeePassXC Browser Integration.",
  "keywords": [
    "tabby-plugin",
    "terminus-plugin"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "webpack --progress --color --mode=production",
    "watch": "webpack --progress --color --watch",
    "prepublishOnly": "npm run build",
    "deploy:local-tabby": "pnpm run build && PLUGIN_DIR=\"$HOME/Library/Application Support/tabby/plugins/node_modules/tabby-vault-keepassxc\" && mkdir -p \"$PLUGIN_DIR/dist\" && cp dist/index.js dist/index.js.LICENSE.txt \"$PLUGIN_DIR/dist/\" && cp package.json \"$PLUGIN_DIR/\" && rm -f \"$PLUGIN_DIR/index.js\" \"$PLUGIN_DIR/index.js.LICENSE.txt\""
  },
  "files": [
    "dist"
  ],
  "author": "chomoe327",
  "license": "MIT",
  "devDependencies": {
    "@angular/animations": "^7.2.8",
    "@angular/common": "^7.2.8",
    "@angular/core": "^7.2.8",
    "@angular/forms": "^7.2.8",
    "@angular/platform-browser": "^7.2.8",
    "@ng-bootstrap/ng-bootstrap": "^2.2.0",
    "@types/node": "^18.19.0",
    "@types/webpack-env": "^1.16.0",
    "apply-loader": "^2.0.0",
    "clean-webpack-plugin": "^0.1.19",
    "css-loader": "^5.1.1",
    "ngx-toastr": "^8.8.0",
    "pug": "^3.0.2",
    "pug-loader": "^2.4.0",
    "rxjs": "^6.2.1",
    "sass": "1.77.8",
    "sass-loader": "^11.0.1",
    "style-loader": "^2.0.0",
    "terminus-core": "^1.0.140",
    "terminus-settings": "^1.0.140",
    "terser-webpack-plugin": "^5.6.1",
    "to-string-loader": "^1.1.6",
    "ts-loader": "^9.2.3",
    "typescript": "^4.3.5",
    "webpack": "^5.88.2",
    "webpack-cli": "^4.5.0"
  },
  "peerDependencies": {
    "@angular/core": "^4.0.1"
  }
}
